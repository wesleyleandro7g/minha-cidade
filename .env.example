# ---------------------------------------------------------------------------
# Minha Cidade - Environment variables
# Copy to .env.local and fill in. The app runs with seed data when Supabase
# variables are absent, so you can develop the public area without a backend.
# ---------------------------------------------------------------------------

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CITY=salinas

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Database (Drizzle / postgres-js) - use the Supabase pooled connection string
DATABASE_URL=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# Asaas (billing - used in later phases)
ASAAS_API_KEY=
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=
